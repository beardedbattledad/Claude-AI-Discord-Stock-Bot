import os
import json
from dotenv import load_dotenv
import httpx
import asyncio

load_dotenv()

UW_API_KEY = os.getenv("UW_API_KEY")

if not UW_API_KEY:
    print("ERROR: UW_API_KEY not found in .env")
    exit(1)

# Your exact custom alert names
CUSTOM_ALERT_NAMES = ["AI Mid Cap", "AI Small Cap", "AI ETF", "AI Mega Cap"]

async def debug_dump():
    print("=== Starting Unusual Whales Custom Alerts Debug Dump ===\n")

    # Step 1: Load alert configurations
    print("1. Fetching alert configurations...")
    try:
        headers = {"Authorization": f"Bearer {UW_API_KEY}"}
        async with httpx.AsyncClient(timeout=15.0) as client:
            resp = await client.get("https://api.unusualwhales.com/api/alerts/configuration", headers=headers)
            print(f"   Configs Status: {resp.status_code}")

            if resp.status_code != 200:
                print(f"   Error: {resp.text[:500]}")
                return

            data = resp.json()
            configs = data.get("data", [])
            print(f"   Found {len(configs)} total alert configs")

            matching = []
            for alert in configs:
                name = alert.get("name")
                aid = alert.get("id")
                if name and aid and name in CUSTOM_ALERT_NAMES:
                    matching.append((name, aid))
                    print(f"   MATCH: '{name}' → ID: {aid}")

            print(f"   Loaded {len(matching)} matching custom alerts: {[n for n, _ in matching]}")

            if not matching:
                print("   No matching alerts found. Check exact names in Unusual Whales dashboard.")
                return

            config_ids = [aid for _, aid in matching]

    except Exception as e:
        print(f"   Config fetch failed: {e}")
        return

    # Step 2: Fetch triggered alerts
    print("\n2. Fetching triggered alerts from your custom filters...")
    try:
        base_url = "https://api.unusualwhales.com"
        params = {"limit": 50}
        for cid in config_ids:
            params.setdefault("config_ids[]", []).append(cid)

        async with httpx.AsyncClient(timeout=20.0) as client:
            resp = await client.get(f"{base_url}/api/alerts", headers=headers, params=params)
            print(f"   Alerts Status: {resp.status_code}")

            if resp.status_code != 200:
                print(f"   Error: {resp.text[:500]}")
                return

            data = resp.json()
            trades = data.get("data", []) if isinstance(data, dict) else []
            print(f"   Received {len(trades)} triggered trades\n")

            # FULL RAW JSON DUMP
            print("=== FULL RAW JSON DUMP (first 5 trades) ===")
            for i, trade in enumerate(trades[:5]):
                print(f"\n--- Trade {i+1} ---")
                print(json.dumps(trade, default=str, indent=2))
                print("-" * 80)

            print("\n=== END OF RAW DUMP ===\n")

            if trades:
                meta = trades[0].get("meta", {})
                print(f"Available top-level keys: {list(trades[0].keys())}")
                print(f"Available meta keys: {list(meta.keys())}")

    except Exception as e:
        print(f"   Alerts fetch failed: {e}")

asyncio.run(debug_dump())